# AOK QA-Bot Konfiguration
# Kopiere diese Datei nach .env und trage deinen Key ein

# API-Key für das LLM-Reranking (erforderlich)
LLM_API_KEY=sk-sp-...

# Passwort für den API-Zugriff (Standard: aok2026)
# AOK_BOT_PASSWORD=aok2026

# Optionale Pfade (Standardwerte werden genutzt, wenn nicht gesetzt)
# MODEL_NAME=intfloat/multilingual-e5-large
# DEFAULT_DB_PATH=index.db
